import { Theme } from "../theme.slint";

export component StatusIndicator inherits Rectangle {
	in property <string> label;
	in property <int> tone;

	height: Theme.fs-label;

	Text {
		x: parent.width - self.width - Theme.sp-lg;
		text: root.label;
		color: Theme.worker-status-text(root.tone);
		font-family: Theme.font-ui;
		font-size: Theme.fs-label;
		font-weight: Theme.fw-semibold;
	}

	Rectangle {
		x: parent.width - self.width;
		width: 10px;
		height: 10px;
		border-radius: 5px;
		background: Theme.worker-status-color(root.tone);
	}
}
