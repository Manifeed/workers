import { Theme } from "../theme.slint";
import { FieldLabel } from "../components/field-label.slint";
import { AppComboBox } from "../controls/app-combo-box.slint";
import { AppLineEdit } from "../controls/app-line-edit.slint";
import { AppSpinBox } from "../controls/app-spin-box.slint";
import { WorkerCardFrame } from "worker-card-frame.slint";

export component EmbeddingWorkerCard inherits WorkerCardFrame {
	in-out property <string> api_key;
	in-out property <int> run_mode_index;
	in-out property <int> acceleration_index;
	in-out property <int> batch_size;
	title: "Embedding Worker";

	FieldLabel { text: "API key"; }

	AppLineEdit {
		height: Theme.btn-height;
		enabled: !root.app_busy;
		text <=> root.api_key;
		placeholder-text: "Bearer token";
		input-type: InputType.password;
	}

	FieldLabel { text: "Run mode"; }

	AppComboBox {
		height: Theme.btn-height;
		enabled: !root.app_busy;
		model: ["On Demand", "Background"];
		current-index <=> root.run_mode_index;
	}

	FieldLabel { text: "Acceleration"; }

	AppComboBox {
		height: Theme.btn-height;
		enabled: !root.app_busy;
		model: ["Auto", "CPU", "GPU"];
		current-index <=> root.acceleration_index;
	}

	FieldLabel { text: "Batch size"; }

	AppSpinBox {
		height: Theme.btn-height;
		enabled: !root.app_busy;
		minimum: 1;
		maximum: 256;
		value <=> root.batch_size;
	}
}
