import { Theme } from "../theme.slint";
import { CardShell } from "../components/card-shell.slint";
import { EditorialButton } from "../components/editorial-button.slint";
import { FieldLabel } from "../components/field-label.slint";
import { NoticeBanner } from "../components/notice-banner.slint";
import { AppLineEdit } from "../controls/app-line-edit.slint";
import { SettingsCardView } from "../view-types.slint";

export component SettingsCard inherits CardShell {
	in-out property <string> api_url;
	in property <bool> app_busy;
	in property <bool> app_read_only;
	in property <SettingsCardView> card;
	callback save_changes;
	callback check_updates;
	callback open_update;
	callback open_release_notes;

	shell_content_height: content.preferred-height;

	content := VerticalLayout {
		alignment: start;
		padding: Theme.sp-2xl;
		spacing: Theme.sp-xl;

		VerticalLayout {
			spacing: Theme.sp-sm;

			Text {
				text: "Settings";
				color: Theme.text-primary;
				font-family: Theme.font-heading;
				font-size: Theme.fs-section-title;
				font-weight: Theme.fw-bold;
			}

			Text {
				text: root.card.version_line;
				color: Theme.text-muted;
				font-family: Theme.font-body;
				font-size: Theme.fs-label;
				wrap: word-wrap;
			}
		}

		if root.card.notice.visible : NoticeBanner {
			notice: root.card.notice;
		}

		VerticalLayout {
			alignment: start;
			spacing: Theme.sp-md;

			HorizontalLayout {
				spacing: Theme.sp-md;

					EditorialButton {
						primary: true;
						text: "Save Changes";
						enabled: !root.app_busy && !root.app_read_only;
						pressed => { root.save_changes(); }
					}

					EditorialButton {
						text: "Check Updates";
						enabled: !root.app_busy && !root.app_read_only;
						pressed => { root.check_updates(); }
					}
			}

			HorizontalLayout {
				spacing: Theme.sp-md;

				EditorialButton {
					text: "Download Update";
					visible: root.card.can_open_update;
					enabled: !root.app_busy && root.card.can_open_update;
					pressed => { root.open_update(); }
				}

				EditorialButton {
					text: "Release Notes";
					visible: root.card.can_open_release_notes;
					enabled: !root.app_busy && root.card.can_open_release_notes;
					pressed => { root.open_release_notes(); }
				}
			}

			VerticalLayout {
				spacing: Theme.sp-sm;

				FieldLabel { text: "API URL"; }

					AppLineEdit {
						height: Theme.btn-height;
						enabled: !root.app_busy && !root.app_read_only;
						text <=> root.api_url;
					placeholder-text: "http://127.0.0.1:8000";
				}
			}
		}
	}
}
