#!/usr/bin/make -f

export DH_VERBOSE = 1

WORKSPACE_DIR := $(abspath $(CURDIR)/../..)

%:
	dh $@

override_dh_auto_build:
	cd $(WORKSPACE_DIR) && cargo build --release -p worker-desktop

override_dh_auto_install:
	bash ./scripts/stage-packages.sh "$(CURDIR)" "$(DEB_HOST_ARCH)"

override_dh_auto_test:

override_dh_auto_clean:
	rm -rf $(CURDIR)/debian/manifeed-workers-desktop
